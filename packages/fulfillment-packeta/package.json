{
  "name": "@medusa-cz/fulfillment-packeta",
  "version": "0.0.1",
  "description": "Packeta / Zásilkovna pickup-point fulfillment for MedusaJS 2.0 (medusa-cz).",
  "license": "MIT",
  "files": [".medusa/server"],
  "exports": {
    "./package.json": "./package.json",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js"
  },
  "keywords": ["medusa", "medusa-plugin", "medusa-v2", "fulfillment", "packeta", "zasilkovna", "czech"],
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.15.5",
    "@medusajs/admin-shared": "2.15.5",
    "@medusajs/cli": "2.15.5",
    "@medusajs/framework": "2.15.5",
    "@medusajs/icons": "2.15.5",
    "@medusajs/medusa": "2.15.5",
    "@medusajs/test-utils": "2.15.5",
    "@medusajs/ui": "4.1.15",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "@medusajs/framework": "2.15.5",
    "@medusajs/medusa": "2.15.5"
  }
}
