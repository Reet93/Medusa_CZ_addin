{
  "name": "@medusa-cz/payment-comgate",
  "version": "0.0.1",
  "description": "Comgate payment provider for MedusaJS 2.0 (medusa-cz).",
  "license": "MIT",
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js"
  },
  "keywords": [
    "medusa",
    "medusa-plugin",
    "medusa-v2",
    "payment",
    "comgate",
    "czech"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --dir src/__tests__/integration",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.17.0",
    "@medusajs/admin-shared": "2.17.0",
    "@medusajs/cli": "2.17.0",
    "@medusajs/framework": "2.17.0",
    "@medusajs/icons": "2.17.0",
    "@medusajs/medusa": "2.17.0",
    "@medusajs/test-utils": "2.17.0",
    "@medusajs/ui": "4.1.17",
    "typescript": "^5.6.2",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@medusajs/framework": "2.17.0",
    "@medusajs/medusa": "2.17.0"
  }
}
